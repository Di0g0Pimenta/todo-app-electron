{
  "name": "todo-calendar-electron",
  "version": "0.1.0-alpha.1",
  "description": "ToDo List com Electron, SQLite e calendario mensal.",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "ng build",
    "dev": "ng build --watch --configuration development",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win --publish never",
    "seed": "set ELECTRON_RUN_AS_NODE=1&& electron scripts/seed-demo.js",
    "test": "node --test tests/*.test.js",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.diogopimenta.todo-calendar",
    "productName": "ToDo Calendar",
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/todo-calendar-electron/browser/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Di0g0Pimenta",
      "repo": "todo-app-electron"
    }
  },
  "keywords": [
    "electron",
    "sqlite",
    "todo",
    "calendar"
  ],
  "author": "Diogo Pimenta",
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "better-sqlite3": "^12.3.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.0"
  }
}
